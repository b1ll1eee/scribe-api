PORT=8080
APP_ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@postgres:5432/scribesdb?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_MAX_LIFETIME=5m

# Redis
REDIS_URL=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ClickHouse
CLICKHOUSE_ADDR=clickhouse:9000
CLICKHOUSE_DB=scribesdb
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production-use-strong-secret
JWT_ACCESS_TOKEN_TTL=15m

# Firebase (leave empty for mock mode)
FIREBASE_CREDENTIALS=
FIREBASE_AUTH_MOCK=true

# CORS
CORS_ORIGIN=http://localhost:3000
